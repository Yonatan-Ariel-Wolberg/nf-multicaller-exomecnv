Bootstrap: docker
From: ubuntu:24.04

%labels
    software="icav2-cli"
    software.version="2.43.0"
    about.summary="Illumina Connected Analytics v2 Command Line Interface"
    about.home="https://help.ica.illumina.com/command-line-interface"
    about.license="Proprietary/Illumina"
    about.tags="genomics, cloud, illumina"

%post
    # 1. Install dependencies
    apt-get update && apt-get install -y curl jq ca-certificates unzip
    
    # 2. Download and extract the official CLI zip file
    curl -sL "https://stratus-documentation-us-east-1-public.s3.amazonaws.com/cli/2.43.0/ica-linux-amd64.zip" -o ica.zip
    unzip ica.zip
    
    # 3. Rename to 'icav2' and make executable
    mv linux-amd64/icav2 /usr/local/bin/icav2
    chmod +x /usr/local/bin/icav2
    
    # 4. Biocontainer standard: Clean up installers and caches to minimize image size
    rm -rf ica.zip linux-amd64/
    apt-get clean
    rm -rf /var/lib/apt/lists/*