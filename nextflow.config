#!/usr/bin/env nextflow
nextflow.enable.dsl=2

// =====================================================================================
// HELPER FUNCTIONS
// =====================================================================================
// Converts a comma-separated list of host paths to Singularity/Apptainer bind-mount
// flags.  Example: '/a,/b /c' → ' -B /a -B /b /c'
// Used by the singularity, apptainer, and icav2-dragen container runOptions below.
def bindMountFlags(String paths) {
    paths ? paths.tokenize(',').collect { ' -B ' + it.trim() }.join('') : ''
}

// =====================================================================================
// GLOBAL FALLBACK PARAMETERS (Overwritten by JSON params files)
// =====================================================================================
params {
    workflow       = 'none'
    outdir         = './results'
    // Comma-separated list of host filesystem paths to bind-mount into every container.
    // This is the easiest way to give the workflow access to your data directories.
    // Example (Wits cluster): '/dataB/aux,/dataG/ddd,/dataG/ddd-2023,/home/ywolberg'
    // Example (other users):  '/data/myproject,/scratch/myuser'
    // Each path becomes a '-B <path>' argument passed to Singularity/Apptainer.
    bind_paths     = ''
    // Extra raw arguments forwarded to the container runtime (Singularity/Apptainer).
    // Use bind_paths for simple directory mounts; use runOptions for advanced flags
    // not covered by bind_paths (e.g. '--no-home', '--writable-tmpfs').
    runOptions     = ''
    // ICAv2-DRAGEN defaults (overridden by params-icav2-dragen.json)
    maxUploadForks = 4
    uploadRetries  = 5
    // ICAv2 CLI container SIF image path and credentials directory.
    // Set these in your params-file or local config before running the dragen workflow.
    icav2_container = '/path/to/icav2_cli.sif'
    icav2_creds_dir = System.getProperty('user.home') + '/.icav2'
    // Batch-size defaults for CANOES and XHMM (medium-cohort values).
    // Overridden by the small/medium/large cohort-size profiles, or by a
    // params-file.  These global defaults ensure that a meaningful value is
    // always available even when no cohort-size profile is selected.
    canoes_batch_size = 100  // BAMs per bedtools multicov job (CANOES)
    xhmm_batch_size   = 50   // BAMs per GATK DepthOfCoverage job (XHMM)
}

// =====================================================================================
// ENGINE SETTINGS
// =====================================================================================
// Singularity – used when Singularity is the container runtime.
// The cache directory is resolved from the NXF_SINGULARITY_CACHEDIR environment
// variable so that all worker nodes share a single image store on a shared
// filesystem (e.g. /spaces/<project>/nxf_cache on the Wits HPC).  When the
// variable is unset the default falls back to $HOME/.singularity/cache.
singularity {
    enabled    = true
    autoMounts = true
    cacheDir   = System.getenv('NXF_SINGULARITY_CACHEDIR') ?: "$HOME/.singularity/cache"
    runOptions = "--cleanenv${bindMountFlags(params.bind_paths)}${params.runOptions ? ' ' + params.runOptions : ''}"
}

// Apptainer – Apptainer is the community successor to Singularity and is the
// container runtime used on the ZA-Wits-Core cluster (Rocky 9).  Nextflow
// ≥22.10 exposes a dedicated `apptainer` scope; earlier versions fall back to
// the `singularity` scope above.  Both are enabled so the workflow works
// regardless of which binary is available on the worker node.
// NXF_SINGULARITY_CACHEDIR is honoured by both runtimes.
// Note: the fallback paths differ between runtimes because each runtime uses
// its own conventional default cache location (~/.singularity vs ~/.apptainer).
apptainer {
    enabled    = true
    autoMounts = true
    cacheDir   = System.getenv('NXF_SINGULARITY_CACHEDIR') ?: "$HOME/.apptainer/cache"
    runOptions = "--cleanenv${bindMountFlags(params.bind_paths)}${params.runOptions ? ' ' + params.runOptions : ''}"
}

executor {
    jobName        = { "${task.name.replaceAll(' ', '_').toUpperCase()}" }
    queueSize      = 500          // Allow up to 500 jobs queued at once for large cohorts
    submitRateLimit = '10/1sec'   // Limit job submission to 10 per second to avoid overwhelming scheduler
    pollInterval   = '30 sec'     // Reduce polling overhead for large runs
}

// =====================================================================================
// PROCESS SETTINGS & CONTAINERS
// =====================================================================================
process {       
    cache          = true    
    stageInMode    = 'symlink'
    stageOutMode   = 'rsync'
    cpus           = 4                    // Default CPUs for higher parallelism
    memory         = 16.GB                 // Adjusted memory for sample processing
    time           = 48.h                   // Increased time limit for longer processes
    maxForks       = 100                   // Support large cohorts; each withLabel block can override
    errorStrategy  = 'finish'              // Continue other tasks even if one fails
    clusterOptions = '--exclude=n04'
    
    // ---------------------------------------------------------------------------------
    // Container Mappings
    // ---------------------------------------------------------------------------------
    withLabel: 'indelible' {
        container = 'docker://phelelani/nf-exomecnv:indelible'
    }
    withLabel: 'xhmm' {
        container = 'docker://phelelani/nf-exomecnv:xhmm'
    }
    withLabel: 'gatk' {
        container      = 'docker://quay.io/biocontainers/gatk4:4.6.2.0--py310hdfd78af_1'
        clusterOptions = "--constraint=avx2"
        memory         = 16.GB                  // Adjusted for GATK
        cpus           = 4
    }
    withLabel: 'picard' {
        container      = 'docker://quay.io/biocontainers/picard:3.4.0--hdfd78af_0'
        clusterOptions = "--constraint=avx2"
        memory         = 16.GB                  // Adjusted for Picard
        cpus           = 4        
    }
    withLabel: 'canoes|R' {
        container = 'docker://phelelani/nf-exomecnv:canoes'
    }
    withLabel: 'clamms|bedtools' {
        container = 'docker://phelelani/nf-exomecnv:clamms'
    }
    withLabel: 'cnvkit' {
        container = 'docker://quay.io/biocontainers/cnvkit:0.9.12--pyhdfd78af_1'
    }
    withLabel: 'survivor' {
        container = 'docker://quay.io/biocontainers/survivor:1.0.7--h077b44d_7'
        memory    = 8.GB
        cpus      = 2                           // Increased to better handle multiple samples
    }
    withLabel: 'truvari' {
        container = 'docker://quay.io/biocontainers/truvari:5.4.0--pyhdfd78af_0'
        memory    = 8.GB
        cpus      = 2
    }
    withLabel: 'pysam' {
        container = 'docker://quay.io/biocontainers/pysam:0.23.3--py313hd07c5dd_2'
        memory    = 4.GB
        cpus      = 1
    }
    withLabel: 'feature_extraction' {
        // Reuse the pysam container: feature_extraction.py requires pysam,
        // pandas, numpy (all bundled in the pysam biocontainer).
        container = 'docker://quay.io/biocontainers/pysam:0.23.3--py313hd07c5dd_2'
        memory    = 8.GB
        cpus      = 2
    }
    withLabel: 'train' {
        // Python training image used by modules-train.nf (bin/train_xgboost.py).
        // Expected packages: xgboost, scikit-learn, imbalanced-learn, pandas, numpy.
        // Keep this pinned for reproducible training runs.
        container = 'docker://quay.io/biocontainers/xgboost:2.0.3--py310h4aa3b51_0'
        memory    = 16.GB
        cpus      = 4
    }
    withLabel: 'bcftools' {
        container = 'docker://quay.io/biocontainers/bcftools:1.23--h3a4d415_0'
    }
    withLabel: 'icav2-dragen' {
        // Set params.icav2_container to the absolute path of your ICAv2 Singularity SIF image.
        // Example: params.icav2_container = '/spaces/myproject/containers/icav2_cli_v2.43.0.sif'
        container   = params.get('icav2_container', '/path/to/icav2_cli.sif')
        // Mount local ICA credentials (~/.icav2) into the container.
        // Override params.icav2_creds_dir if your credentials live elsewhere.
        // bind_paths and runOptions are also forwarded so that user data directories
        // are accessible inside the DRAGEN container.
        runOptions  = "--cleanenv${bindMountFlags(params.bind_paths)}${params.runOptions ? ' ' + params.runOptions : ''} -B ${params.get('icav2_creds_dir', System.getProperty('user.home') + '/.icav2')}:/root/.icav2"
        maxRetries  = 5                 // Increased retries for connection stability
        // Exit status 100 signals a critical unrecoverable error (e.g. ICA auth failure) — terminate immediately
        errorStrategy = { task.exitStatus == 100 ? 'terminate' : 'retry' }
    }

    // ---------------------------------------------------------------------------------
    // Dynamic Resource Constraints (For GCNV/CNVkit)
    // ---------------------------------------------------------------------------------
    withLabel: 'large_mem' {
        memory = 64.GB
        cpus   = 8
    }
    withLabel: 'gpu_or_high_cpu' {
        memory = 32.GB
        cpus   = 16
    }
}

// =====================================================================================
// PROFILES
// =====================================================================================
profiles {
    // wits – University of the Witwatersrand (Wits) UI Linux HPC cluster
    // Uses the SLURM scheduler.  Combine with a cohort-size profile:
    //   nextflow run main.nf -profile wits,small  -params-file params/params-canoes.json
    //
    // Before running, set NXF_SINGULARITY_CACHEDIR to a path on a shared volume
    // that is accessible by all worker nodes, e.g.:
    //   export NXF_SINGULARITY_CACHEDIR=/spaces/<project>/nxf_cache
    //
    // This profile targets CPU-only worker nodes.  GPU-accelerated processes
    // (e.g. Parabricks) are not submitted because no --gres=gpu clusterOptions
    // are set here; add a dedicated GPU profile if GPU nodes become available.
    wits {
        executor.name            = 'slurm'
        executor.queueSize       = 500
        executor.submitRateLimit = '10/1sec'
        executor.pollInterval    = '30 sec'
        process {
            queue  = 'batch'
            cpus   = 4        // Default CPUs per SLURM job
            memory = '16 GB'  // Default memory per SLURM job
            time   = '72h'    // Default wall-clock limit per SLURM job
        }
        // Singularity/Apptainer cache on a shared /spaces volume so that images
        // are downloaded once and reused by all worker nodes.
        singularity.cacheDir = System.getenv('NXF_SINGULARITY_CACHEDIR') ?: "$HOME/.singularity/cache"
        apptainer.cacheDir   = System.getenv('NXF_SINGULARITY_CACHEDIR') ?: "$HOME/.apptainer/cache"
    }

    // ---------------------------------------------------------------------------------
    // COHORT-SIZE PROFILES
    // Use one of these alongside the executor profile (e.g. -profile wits,small).
    // They tune queueSize, submission rate, per-process concurrency, and batch sizes
    // so that the scheduler is not overwhelmed at small scale or under-utilised at
    // large scale.
    // ---------------------------------------------------------------------------------

    // small – up to ~50 samples
    // Low concurrency avoids flooding the scheduler with short-lived jobs.
    small {
        executor.queueSize       = 100
        executor.submitRateLimit = '5/1sec'
        process.maxForks         = 25
        params {
            canoes_batch_size = 50   // single bedtools multicov batch for ≤50 BAMs
            xhmm_batch_size   = 25   // single GATK DepthOfCoverage batch for ≤25 BAMs
        }
    }

    // medium – 50–300 samples (default behaviour)
    // Matches the global defaults; made explicit so it can be named on the command line.
    medium {
        executor.queueSize       = 500
        executor.submitRateLimit = '10/1sec'
        process.maxForks         = 100
        params {
            canoes_batch_size = 100  // ~3 batches per chromosome for 300 samples
            xhmm_batch_size   = 50   // 6 GATK DOC batches for 300 samples
        }
    }

    // large – 300–2000 samples
    // Higher queue and submission limits; bigger batches keep per-chromosome job
    // counts manageable; cohort-level GATK/gCNV steps get extra memory/CPUs.
    large {
        executor.queueSize       = 2000
        executor.submitRateLimit = '20/1sec'
        process.maxForks         = 200
        params {
            canoes_batch_size = 200  // 10 batches per chromosome for 2000 samples
            xhmm_batch_size   = 100  // 20 GATK DOC batches for 2000 samples
        }
        process {
            withLabel: 'gatk' {
                memory = 32.GB
                cpus   = 8
            }
            withLabel: 'large_mem' {
                memory = 128.GB
                cpus   = 16
            }
            withLabel: 'gpu_or_high_cpu' {
                memory = 64.GB
                cpus   = 32
            }
        }
    }

    // ---------------------------------------------------------------------------------
    // wits_gpu – GPU-accelerated profile for NVIDIA L4 nodes on ZA-Wits-Core
    //
    // Use alongside the `wits` profile to enable Parabricks-accelerated alignment
    // and variant calling on the GPU-equipped worker nodes (e.g. n16.core.wits.ac.za):
    //
    //   nextflow run main.nf -profile wits,wits_gpu -params-file params/params-canoes.json
    //
    // GPU jobs are submitted to nodes that carry NVIDIA L4 or Tesla K20Xm hardware
    // using the --gres=gpu:1 SLURM generic resource request together with the
    // --reservation=gpu reservation maintained by the Wits HPC team.
    //
    // This profile only overrides the RUN_PARABRICKS process.  All other processes
    // continue to run on CPU nodes as directed by the wits profile.
    // ---------------------------------------------------------------------------------
    wits_gpu {
        process {
            withName: 'RUN_PARABRICKS' {
                // Request one GPU via SLURM's generic resource (gres) mechanism and
                // target the dedicated GPU reservation on the Wits cluster.
                clusterOptions = '--gres=gpu:1 --reservation=gpu'
                container      = 'docker://nvcr.io/nvidia/clara/clara-parabricks:4.0.1-1'
                // Parabricks requires substantial CPU and RAM to stage data while the
                // GPU accelerates alignment.  These defaults match the Wits L4 nodes.
                memory         = '32 GB'
                cpus           = 16
                time           = '24h'
            }
        }
    }
}

// =====================================================================================
// REPORTING
// =====================================================================================
trace {
    enabled   = true
    overwrite = true
    file      = "${launchDir}/exec_reports/${params.workflow}_trace.txt"
}
timeline {
    enabled   = true
    overwrite = true
    file      = "${launchDir}/exec_reports/${params.workflow}_timeline.html"
}
report {
    enabled   = true
    overwrite = true
    file      = "${launchDir}/exec_reports/${params.workflow}_report.html"
}
