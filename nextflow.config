#!/usr/bin/env nextflow
nextflow.enable.dsl=2

// =====================================================================================
// GLOBAL FALLBACK PARAMETERS (Overwritten by JSON params files)
// =====================================================================================
params {
    workflow       = 'none'
    outdir         = './results'
    runOptions     = '-B /dataB/aux -B /dataG/ddd -B /dataG/ddd-2023 -B /home/ywolberg'
    // ICAv2-DRAGEN defaults (overridden by params-icav2-dragen.json)
    maxUploadForks = 4
    uploadRetries  = 5
    // Batch-size defaults for CANOES and XHMM (medium-cohort values).
    // Overridden by the small/medium/large cohort-size profiles, or by a
    // params-file.  These global defaults ensure that a meaningful value is
    // always available even when no cohort-size profile is selected.
    canoes_batch_size = 100  // BAMs per bedtools multicov job (CANOES)
    xhmm_batch_size   = 50   // BAMs per GATK DepthOfCoverage job (XHMM)
}

// =====================================================================================
// ENGINE SETTINGS
// =====================================================================================
singularity {
    enabled    = true
    autoMounts = true
    cacheDir   = "$HOME/.singularity/cache"
    runOptions = "--cleanenv ${params.runOptions}"
}

executor {
    jobName        = { "${task.name.replaceAll(' ', '_').toUpperCase()}" }
    queueSize      = 500          // Allow up to 500 jobs queued at once for large cohorts
    submitRateLimit = '10/1sec'   // Limit job submission to 10 per second to avoid overwhelming scheduler
    pollInterval   = '30 sec'     // Reduce polling overhead for large runs
}

// =====================================================================================
// PROCESS SETTINGS & CONTAINERS
// =====================================================================================
process {       
    cache          = true    
    stageInMode    = 'symlink'
    stageOutMode   = 'rsync'
    cpus           = 4                    // Default CPUs for higher parallelism
    memory         = 16.GB                 // Adjusted memory for sample processing
    time           = 48.h                   // Increased time limit for longer processes
    maxForks       = 100                   // Support large cohorts; each withLabel block can override
    errorStrategy  = 'finish'              // Continue other tasks even if one fails
    clusterOptions = '--exclude=n04'
    
    // ---------------------------------------------------------------------------------
    // Container Mappings
    // ---------------------------------------------------------------------------------
    withLabel: 'indelible' {
        container = 'docker://phelelani/nf-exomecnv:indelible'
    }
    withLabel: 'xhmm' {
        container = 'docker://phelelani/nf-exomecnv:xhmm'
    }
    withLabel: 'gatk' {
        container      = 'docker://quay.io/biocontainers/gatk4:4.6.2.0--py310hdfd78af_1'
        clusterOptions = "--constraint=avx2"
        memory         = 16.GB                  // Adjusted for GATK
        cpus           = 4
    }
    withLabel: 'picard' {
        container      = 'docker://quay.io/biocontainers/picard:3.4.0--hdfd78af_0'
        clusterOptions = "--constraint=avx2"
        memory         = 16.GB                  // Adjusted for Picard
        cpus           = 4        
    }
    withLabel: 'canoes|R' {
        container = 'docker://phelelani/nf-exomecnv:canoes'
    }
    withLabel: 'clamms|bedtools' {
        container = 'docker://phelelani/nf-exomecnv:clamms'
    }
    withLabel: 'cnvkit' {
        container = 'docker://quay.io/biocontainers/cnvkit:0.9.12--pyhdfd78af_1'
    }
    withLabel: 'survivor' {
        container = 'docker://quay.io/biocontainers/survivor:1.0.7--h077b44d_7'
        memory    = 8.GB
        cpus      = 2                           // Increased to better handle multiple samples
    }
    withLabel: 'truvari' {
        container = 'docker://quay.io/biocontainers/truvari:5.4.0--pyhdfd78af_0'
        memory    = 8.GB
        cpus      = 2
    }
    withLabel: 'pysam' {
        container = 'docker://quay.io/biocontainers/pysam:0.22.1--py310hc045571_1'
        memory    = 4.GB
        cpus      = 1
    }
    withLabel: 'bcftools' {
        container = 'docker://quay.io/biocontainers/bcftools:1.23--h3a4d415_0'
    }
    withLabel: 'icav2-dragen' {
        // IMPORTANT: Replace this with the actual path to the ICAv2 container you created
        container   = '/home/ywolberg/containers/icav2_cli_v2.43.0.sif'
        // Optional: If you need to mount local ICA credentials into the container
        runOptions  = "--cleanenv ${params.runOptions} -B /home/ywolberg/.icav2:/root/.icav2"
        maxRetries  = 5                 // Increased retries for connection stability
        // Exit status 100 signals a critical unrecoverable error (e.g. ICA auth failure) — terminate immediately
        errorStrategy = { task.exitStatus == 100 ? 'terminate' : 'retry' }
    }

    // ---------------------------------------------------------------------------------
    // Dynamic Resource Constraints (For GCNV/CNVkit)
    // ---------------------------------------------------------------------------------
    withLabel: 'large_mem' {
        memory = 64.GB
        cpus   = 8
    }
    withLabel: 'gpu_or_high_cpu' {
        memory = 32.GB
        cpus   = 16
    }
}

// =====================================================================================
// PROFILES
// =====================================================================================
profiles {
    // wits – University of the Witwatersrand (Wits) UI Linux HPC cluster
    // Uses the SLURM scheduler.  Combine with a cohort-size profile:
    //   nextflow run main.nf -profile wits,small  -params-file params/params-canoes.json
    wits {
        executor.name            = 'slurm'
        executor.queueSize       = 500
        executor.submitRateLimit = '10/1sec'
        executor.pollInterval    = '30 sec'
        process {
            queue  = 'batch'
            cpus   = 4        // Default CPUs per SLURM job
            memory = '16 GB'  // Default memory per SLURM job
            time   = '72h'    // Default wall-clock limit per SLURM job
        }
    }

    // ---------------------------------------------------------------------------------
    // COHORT-SIZE PROFILES
    // Use one of these alongside the executor profile (e.g. -profile wits,small).
    // They tune queueSize, submission rate, per-process concurrency, and batch sizes
    // so that the scheduler is not overwhelmed at small scale or under-utilised at
    // large scale.
    // ---------------------------------------------------------------------------------

    // small – up to ~50 samples
    // Low concurrency avoids flooding the scheduler with short-lived jobs.
    small {
        executor.queueSize       = 100
        executor.submitRateLimit = '5/1sec'
        process.maxForks         = 25
        params {
            canoes_batch_size = 50   // single bedtools multicov batch for ≤50 BAMs
            xhmm_batch_size   = 25   // single GATK DepthOfCoverage batch for ≤25 BAMs
        }
    }

    // medium – 50–300 samples (default behaviour)
    // Matches the global defaults; made explicit so it can be named on the command line.
    medium {
        executor.queueSize       = 500
        executor.submitRateLimit = '10/1sec'
        process.maxForks         = 100
        params {
            canoes_batch_size = 100  // ~3 batches per chromosome for 300 samples
            xhmm_batch_size   = 50   // 6 GATK DOC batches for 300 samples
        }
    }

    // large – 300–2000 samples
    // Higher queue and submission limits; bigger batches keep per-chromosome job
    // counts manageable; cohort-level GATK/gCNV steps get extra memory/CPUs.
    large {
        executor.queueSize       = 2000
        executor.submitRateLimit = '20/1sec'
        process.maxForks         = 200
        params {
            canoes_batch_size = 200  // 10 batches per chromosome for 2000 samples
            xhmm_batch_size   = 100  // 20 GATK DOC batches for 2000 samples
        }
        process {
            withLabel: 'gatk' {
                memory = 32.GB
                cpus   = 8
            }
            withLabel: 'large_mem' {
                memory = 128.GB
                cpus   = 16
            }
            withLabel: 'gpu_or_high_cpu' {
                memory = 64.GB
                cpus   = 32
            }
        }
    }
}

// =====================================================================================
// REPORTING
// =====================================================================================
trace {
    enabled   = true
    overwrite = true
    file      = "${launchDir}/exec_reports/${params.workflow}_trace.txt"
}
timeline {
    enabled   = true
    overwrite = true
    file      = "${launchDir}/exec_reports/${params.workflow}_timeline.html"
}
report {
    enabled   = true
    overwrite = true
    file      = "${launchDir}/exec_reports/${params.workflow}_report.html"
}
